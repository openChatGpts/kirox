# 默认：所有文本文件统一使用 LF
* text=auto eol=lf

# Go 源码
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Web 前端
*.html text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.svg text eol=lf

# 配置 / 文档
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
LICENSE text eol=lf

# Windows 批处理脚本保留 CRLF（cmd.exe 要求）
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件，不做换行转换
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.icns binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.zip binary
*.tar binary
*.gz binary
